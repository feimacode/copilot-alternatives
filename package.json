				{
					"command": "copilotAlternatives.clearSessionFilter",
					"when": "view == copilotAlternatives.main && viewItem == sessionSection",
					"group": "inline"
				},
				{
					"command": "copilotAlternatives.showSessionDetail",
					"when": "view == copilotAlternatives.main && viewItem == sessionNode",
					"group": "inline"
				},
				{
					"command": "copilotAlternatives.copySessionId",
					"when": "view == copilotAlternatives.main && viewItem == sessionNode",
					"group": "1_edit"
				},
				{
					"command": "copilotAlternatives.openHelpDoc",
					"when": "view == copilotAlternatives.main && viewItem == helpItem",
					"group": "inline"
				}
			]
		}
	},
	"configuration": {
		"title": "Copilot Alternatives — Token Usage",
		"properties": {
			"copilotAlternatives.tokenUsage.backfillDays": {
				"type": "number",
				"default": 60,
				"minimum": 1,
				"maximum": 365,
				"description": "Number of days of chat history to import from disk. Older sessions are skipped for performance. Increase this value then reload token usage data to include older sessions."
			},
			"copilotAlternatives.tokenUsage.watcherWindowDays": {
				"type": "number",
				"default": 1,
				"minimum": 1,
				"maximum": 30,
				"description": "How far back (in days) the real-time file watcher scans for chat session files on startup. Keep small (default 1 day) for fast activation. Historical data is still imported by the background processor."
			},
			"copilotAlternatives.tokenUsage.yearlyBudgetTarget": {
				"type": "number",
				"default": 250000,
				"minimum": 1,
				"description": "Yearly AI token budget target in USD. Displayed as a progress bar in the token usage overview dashboard."
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"test": "vitest run",
		"test:watch": "vitest",
		"package": "vsce package --readme-path EXTENSION_README.md --allow-star-activation",
		"package:linux": "vsce package --readme-path EXTENSION_README.md --target linux-x64 --allow-star-activation",
		"package:win": "vsce package --readme-path EXTENSION_README.md --target win32-x64 --allow-star-activation",
		"package:mac-arm": "vsce package --readme-path EXTENSION_README.md --target darwin-arm64 --allow-star-activation"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/sqlite3": "^3.1.11",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^2.22.0",
		"tar": "^7.5.20",
		"typescript": "^5.3.0",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@vscode/sqlite3": "^5.1.2",
		"chart.js": "^4.5.1"
	}
}
