					"group": "inline"
				},
				{
					"command": "copilotAlternatives.byok.deleteProvider",
					"when": "view == copilotAlternatives.main && viewItem == byokProvider",
					"group": "inline"
				},
				{
					"command": "copilotAlternatives.byok.openJsonFile",
					"when": "view == copilotAlternatives.main && viewItem == byokProvider",
					"group": "inline"
				},
				{
					"command": "copilotAlternatives.byok.remove",
					"when": "view == copilotAlternatives.main && viewItem == byokProvider"
				},
				{
					"command": "copilotAlternatives.byok.editModel",
					"when": "view == copilotAlternatives.main && viewItem == byokModel",
					"group": "inline"
				},
				{
					"command": "copilotAlternatives.byok.deleteModel",
					"when": "view == copilotAlternatives.main && viewItem == byokModel",
					"group": "inline"
				},
				{
					"command": "copilotAlternatives.copyEndpointUrl",
					"when": "view == copilotAlternatives.main && viewItem == byokModel"
				},
				{
					"command": "copilotAlternatives.installExtension",
					"when": "view == copilotAlternatives.main && viewItem == extensionItem",
					"group": "inline"
				},
				{
					"command": "copilotAlternatives.openUrl",
					"when": "view == copilotAlternatives.main && viewItem == extensionItem"
				},
				{
					"command": "copilotAlternatives.viewDetails",
					"when": "view == copilotAlternatives.main && viewItem == extensionItem"
				},
				{
					"command": "copilotAlternatives.openReadme",
					"when": "view == copilotAlternatives.main && viewItem == moreInfoSection",
					"group": "inline"
				},
				{
					"command": "copilotAlternatives.openUsageOverview",
