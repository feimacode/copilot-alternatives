			"view/title": [
				{
					"command": "copilotAlternatives.byok.addProviderInline",
					"when": "view == copilotAlternatives.main",
					"group": "navigation"
				},
				{
					"command": "copilotAlternatives.byok.openJsonFile",
					"when": "view == copilotAlternatives.main",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "copilotAlternatives.byok.addProviderInline",
					"when": "view == copilotAlternatives.main && viewItem == byokSection",
					"group": "inline"
				},
				{
					"command": "copilotAlternatives.byok.addMultiKeyProvider",
					"when": "view == copilotAlternatives.main && viewItem == byokSection",
					"group": "inline"
				},
				{
